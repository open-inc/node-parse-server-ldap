{
  "name": "@openinc/parse-server-ldap",
  "version": "0.7.0",
  "description": "Parse Server Cloud Code to authenticate with LDAP/AD",
  "packageManager": "pnpm@11.15.1",
  "type": "module",
  "keywords": [
    "parse",
    "ldap"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-inc/node-parse-server-ldap.git"
  },
  "main": "dist/index.js",
  "license": "MIT",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "release": {
    "branches": [
      "master"
    ],
    "repositoryUrl": "https://github.com/open-inc/node-parse-server-ldap.git",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      "semantic-release-export-data"
    ],
    "prepare": [
      "@semantic-release/changelog",
      "@semantic-release/npm",
      {
        "path": "@semantic-release/git",
        "assets": [
          "package.json",
          "pnpm-lock.yaml",
          "CHANGELOG.md"
        ],
        "message": "chore(release): Release ${nextRelease.version} \n\n${nextRelease.notes}"
      }
    ]
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "ldapts": "9.0.0"
  },
  "peerDependencies": {
    "parse": ">=6"
  },
  "devDependencies": {
    "@opendash/tsconfig": "3.0.0-nightly.10",
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^11.0.0",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.1.1",
    "parse": "^8.6.0",
    "semantic-release": "^25.0.8",
    "semantic-release-export-data": "^1.2.0",
    "typescript": "^7.0.2"
  },
  "prettier": {
    "printWidth": 120
  }
}
